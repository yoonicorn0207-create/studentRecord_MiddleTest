<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
	xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xmlns:context="http://www.springframework.org/schema/context"
	xsi:schemaLocation="http://www.springframework.org/schema/beans http://www.springframework.org/schema/beans/spring-beans.xsd
		http://www.springframework.org/schema/context http://www.springframework.org/schema/context/spring-context-4.3.xsd">

	<bean id="hello_ccycode" class="com.kopo.cycode.pojo.Hello">
		<property name="name" value="ccy_123"></property>
		<property name="printer" ref="stringPrinter"></property>

	</bean>
	
 <!-- 어노테이션 Component 가 없을경우 등록 -->
<bean id="hello" class="com.kopo.cycode.pojo.Hello">
		<property name="name" value="ccy_spring"></property>
		<property name="printer" ref="stringPrinter"></property>

	</bean> 

<!--  어노테이션 Component 가 없을경우 등록 -->
	<bean id="stringPrinter" class="com.kopo.cycode.pojo.StringPrinter"></bean>
	<bean id="consolePrinter" class="com.kopo.cycode.pojo.ConsolePrinter"></bean>


</beans>
